# ~/.config/claw/.env  (or ~/ai/claw-code/.env)

# ── Google / Gemini OAuth App Credentials ──────────────────────────────
# Public OAuth app credentials from official Gemini CLI
# These identify the APP, not you — safe to commit if needed
GEMINI_CLIENT_ID=
GEMINI_CLIENT_SECRET=

# ── Default Model ──────────────────────────────────────────────────────
CLAW_DEFAULT_MODEL=

# ── Token / Output Limits ──────────────────────────────────────────────
CLAW_MAX_TOKENS=1058947

# ── Anthropic (if you use Claude models) ──────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI / OpenRouter (if you use those) ────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ── xAI Grok ──────────────────────────────────────────────────────────
# XAI_API_KEY=...

# ── Google Cloud Project (optional, auto-resolved if not set) ─────────
# GOOGLE_CLOUD_PROJECT=your-project-id